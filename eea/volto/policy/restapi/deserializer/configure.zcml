<configure
    xmlns="http://namespaces.zope.org/zope"
    i18n_domain="plone.restapi"
    >

  <adapter factory=".dxfields.DatetimeFieldDeserializer" />


  <!-- EEA Settings controlpanel deserializer -->
  <adapter factory=".controlpanels.EEASettingsControlpanelDeserializer"
      for="eea.volto.policy.interfaces.IEEASettingsControlpanel"
      provides="plone.restapi.interfaces.IDeserializeFromJson"
      />

</configure>
